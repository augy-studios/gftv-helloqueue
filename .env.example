# HelloQueue – Environment Variables Reference
# Copy this to .env for local dev, or set in Vercel dashboard for production.
# NEVER commit actual values to git.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key (not anon)

# ─── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot → token for @GFTVHelloQueueBot
TELEGRAM_BOT_TOKEN=7123456789:AAE-xxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App (used by bot only) ──────────────────────────────────────────────────
WEBAPP_URL=https://queue.gftv.asia

# ─── Notes ───────────────────────────────────────────────────────────────────
# The Vercel deployment uses SUPABASE_URL, SUPABASE_SERVICE_KEY, TELEGRAM_BOT_TOKEN.
# WEBAPP_URL is only needed by the VPS bot process.
#
# For the bot on your Debian VPS, create a .env in ~/helloqueue-bot/ and
# load it via dotenv or export manually in your tmux session:
#   export TELEGRAM_BOT_TOKEN="..."
#   export SUPABASE_URL="..."
#   export SUPABASE_SERVICE_KEY="..."
#   export WEBAPP_URL="https://queue.gftv.asia"
#   node index.js
