{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "outputDirectory": ".",
    "cleanUrls": true,
    "regions": ["sin1"],
    "rewrites": [{
            "source": "/api/auth/:path*",
            "destination": "/api/auth/:path*"
        },
        {
            "source": "/api/events/:path*",
            "destination": "/api/events/:path*"
        },
        {
            "source": "/api/queues/:path*",
            "destination": "/api/queues/:path*"
        },
        {
            "source": "/api/display/:path*",
            "destination": "/api/display/:path*"
        },
        {
            "source": "/api/telegram/:path*",
            "destination": "/api/telegram/:path*"
        },
        {
            "source": "/api/user/:path*",
            "destination": "/api/user/:path*"
        },
        {
            "source": "/dashboard",
            "destination": "/dashboard"
        },
        {
            "source": "/dashboard/:path*",
            "destination": "/dashboard"
        },
        {
            "source": "/login",
            "destination": "/login"
        },
        {
            "source": "/register",
            "destination": "/register"
        },
        {
            "source": "/queue/:eventCode/:queueCode",
            "destination": "/attendee"
        },
        {
            "source": "/display/:eventCode/:queueCode",
            "destination": "/display"
        },
        {
            "source": "/",
            "destination": "/index"
        }
    ],
    "headers": [{
        "source": "/api/(.*)",
        "headers": [{
                "key": "Access-Control-Allow-Origin",
                "value": "*"
            },
            {
                "key": "Access-Control-Allow-Methods",
                "value": "GET,POST,PUT,DELETE,OPTIONS"
            },
            {
                "key": "Access-Control-Allow-Headers",
                "value": "Content-Type, Authorization"
            }
        ]
    }]

}